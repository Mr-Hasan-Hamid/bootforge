# BootForge Environment Variables
# Copy this to .env.local for local dev, and add to Vercel dashboard for production

# ── Cloudflare R2 CDN ──────────────────────────────────────────────────────────
# Your R2 bucket's public URL (found in Cloudflare → R2 → bucket → Settings → Public Access)
# Example: https://pub-abc123def456.r2.dev
NEXT_PUBLIC_R2_BASE_URL=

# ── Optional: Cloudflare Account ID (for programmatic access if needed) ────────
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_R2_ACCESS_KEY_ID=
# CLOUDFLARE_R2_SECRET_ACCESS_KEY=
